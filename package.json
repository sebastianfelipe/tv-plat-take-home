{
  "name": "tv-plat-take-home",
  "version": "1.0.0",
  "private": true,
  "description": "Take-home seed: a small REST API over Postgres with raw SQL.",
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:reset": "tsx scripts/migrate.ts && tsx scripts/seed.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^18.2.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
